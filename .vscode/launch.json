{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenFHE",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/examples/pke/simple-real-numbers",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,

      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",

      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Skip standard libraries",
          "text": "skip -rfu ^std::",
          "ignoreFailures": true
        },
        {
          "description": "Skip libc",
          "text": "skip -rfu ^__.*",
          "ignoreFailures": true
        },
        {
          "description": "Demangle symbols",
          "text": "set print demangle on",
          "ignoreFailures": true
        }
      ],

      "logging": {
        "engineLogging": false
      }
    }
  ]
}